# Base URL for the API (must include /api path).
# Local dev:
VITE_API_URL=http://127.0.0.1:3000/api
# Production build (set before `npm run build`):
# VITE_API_URL=https://alemmartapi.alemmart.com/api

# Match server APP_TIMEZONE for order Created column display.
VITE_APP_TIMEZONE=Africa/Addis_Ababa
